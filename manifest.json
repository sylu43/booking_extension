{
  "manifest_version": 3,
  "name": "Booking Automation",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "identity", "storage", "tabs", "downloads", "alarms"],
  "host_permissions": [
    "https://admin.booking.com/*",
    "https://sheets.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "824987411505-bo618ferbcm4vplqc1oqahe35uccuebg.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://admin.booking.com/hotel/hoteladmin/extranet_ng/manage/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
